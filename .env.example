# 复制此文件为 .env，填入真实值，.env 不要提交 Git
# Copy this file to .env and fill in your actual values; never commit .env

# MySQL Docker 容器 root 密码（compose 内部使用）
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password

# Flask 应用连接 MySQL 所用账号密码
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=oumi
DB_PASSWORD=CHANGE_ME_app_password
DB_NAME=beacon_proc_risk

# Flask Secret Key（可随机生成：python -c "import secrets; print(secrets.token_hex(32))"）
SECRET_KEY=CHANGE_ME_secret_key
